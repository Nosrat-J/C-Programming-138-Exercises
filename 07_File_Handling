// 120. Store Student Records as Structures and Sort them by Age or ID
#include <stdio.h>
struct Student {
    int id;
    char name[50];
    int age;
};
int main() {
    int n, choice;
    printf("Enter number of students: ");
    scanf("%d", &n);
    struct Student s[n], temp;
    for (int i = 0; i < n; i++) {
        printf("ID: "); scanf("%d", &s[i].id);
        printf("Name: "); scanf("%s", s[i].name);
        printf("Age: "); scanf("%d", &s[i].age);
    }
    printf("Sort by (1.ID 2.Age): ");
    scanf("%d", &choice);
    for (int i = 0; i < n - 1; i++)
        for (int j = 0; j < n - i - 1; j++) {
            if ((choice == 1 && s[j].id > s[j + 1].id) ||
                (choice == 2 && s[j].age > s[j + 1].age)) {
                temp = s[j];
                s[j] = s[j + 1];
                s[j + 1] = temp;
            }
        }
    printf("\nSorted:\n");
    for (int i = 0; i < n; i++)
        printf("%d %s %d\n", s[i].id, s[i].name, s[i].age);
    return 0;
}

// 121. Read/Write Structure to a File
