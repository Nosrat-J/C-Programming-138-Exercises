    printf("Enter time in HH:MM (use _ for unknown): ");
    scanf("%s", time);
    if (time[0] == '_') time[0] = (time[1] >= '4' && time[1] <= '9') ? '1' : '2';
    if (time[1] == '_') time[1] = (time[0] == '2') ? '3' : '9';
    if (time[3] == '_') time[3] = '5';
    if (time[4] == '_') time[4] = '9';
    printf("Maximized time: %s\n", time);
    return 0;
}

