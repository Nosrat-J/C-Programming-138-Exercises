// 125. Compare Two Files and Report Mismatches
#include <stdio.h>
int main() {
    FILE *f1, *f2;
    char file1[100], file2[100];
    char ch1, ch2;
    int line = 1, pos = 1, mismatch = 0;
    printf("Enter first filename: "); scanf("%s", file1);
    printf("Enter second filename: "); scanf("%s", file2);
    f1 = fopen(file1, "r");
    f2 = fopen(file2, "r");
    if (f1 == NULL || f2 == NULL) { printf("Error opening files.\n"); return 1; }
    while (((ch1 = fgetc(f1)) != EOF) && ((ch2 = fgetc(f2)) != EOF)) {
        if (ch1 != ch2) {
            printf("Mismatch at line %d, position %d: '%c' vs '%c'\n", line, pos, ch1, ch2);
            mismatch = 1;
            break;
        }
        if (ch1 == '\n') { line++; pos = 1; }
        else pos++;
    }
    if (!mismatch && (fgetc(f1) != EOF || fgetc(f2) != EOF))
        printf("Files have different sizes.\n");
    else if (!mismatch) printf("Files are identical.\n");
    fclose(f1); fclose(f2);
    return 0;
}

// 126. Copy One File into Another File
