// 137. Print Prime Numbers Using Sieve of Eratosthenes
#include <stdio.h>
#include <string.h>
void sieve(int n) {
    int prime[n + 1];
    memset(prime, 1, sizeof(prime));
    prime[0] = prime[1] = 0;
    for (int p = 2; p * p <= n; p++)
        if (prime[p])
            for (int i = p * p; i <= n; i += p)
                prime[i] = 0;
    for (int p = 2; p <= n; p++)
        if (prime[p]) printf("%d ", p);
    printf("\n");
}
int main() {
    int n;
    printf("Enter limit: ");
    scanf("%d", &n);
    sieve(n);
    return 0;
}

// 138. Calculate Power Without Using pow() Function
#include <stdio.h>
double power(double base, int exp) {
    double result = 1.0;
    int positiveExp = (exp > 0) ? exp : -exp;
    for (int i = 0; i < positiveExp; i++) result *= base;
    if (exp < 0) result = 1.0 / result;
    return result;
}
int main() {
    double base;
    int exp;
    printf("Enter base and exponent: ");
    scanf("%lf %d", &base, &exp);
    printf("Result = %.4lf\n", power(base, exp));
    return 0;
}
