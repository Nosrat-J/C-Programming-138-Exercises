// 72. Array Rotation (Left)
#include <stdio.h>
int main() {
    int n, d;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    int arr[n];
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);
    printf("Enter number of left rotations: ");
    scanf("%d", &d);
    d = d % n;
    int temp[d];
    for (int i = 0; i < d; i++) temp[i] = arr[i];
    for (int i = d; i < n; i++) arr[i - d] = arr[i];
    for (int i = 0; i < d; i++) arr[n - d + i] = temp[i];
    printf("Rotated array: ");
    for (int i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\n");
    return 0;
}

// 73. Sort the 2D Array Across Rows
#include <stdio.h>
void sortRow(int row[], int cols) {
    for (int i = 0; i < cols - 1; i++)
        for (int j = 0; j < cols - i - 1; j++)
            if (row[j] > row[j + 1]) {
                int temp = row[j];
                row[j] = row[j + 1];
                row[j + 1] = temp;
            }
}
int main() {
    int rows, cols;
    printf("Enter rows and columns: ");
    scanf("%d %d", &rows, &cols);
    int arr[rows][cols];
    printf("Enter elements:\n");
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            scanf("%d", &arr[i][j]);
    for (int i = 0; i < rows; i++)
        sortRow(arr[i], cols);
    printf("Row-sorted matrix:\n");
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++)
            printf("%d ", arr[i][j]);
        printf("\n");
    }
    return 0;
}
