    fgets(str, sizeof(str), stdin);
    int mark[26] = {0};
    for (int i = 0; str[i]; i++) {
        if (isalpha(str[i])) {
            char ch = tolower(str[i]);
            mark[ch - 'a'] = 1;
        }
    }
    int pangram = 1;
    for (int i = 0; i < 26; i++)
        if (mark[i] == 0) { pangram = 0; break; }
    if (pangram) printf("Pangram\n");
    else printf("Not a pangram\n");
    return 0;
}

