// 89. Remove Duplicate Words from a String
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
int main() {
    char str[200];
    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);
    char *words[100];
    int count = 0;
    char *token = strtok(str, " \t\n");
    while (token != NULL) {
        int duplicate = 0;
        for (int i = 0; i < count; i++)
            if (strcmp(words[i], token) == 0) { duplicate = 1; break; }
        if (!duplicate) words[count++] = token;
        token = strtok(NULL, " \t\n");
    }
    printf("After removing duplicates: ");
    for (int i = 0; i < count; i++) printf("%s ", words[i]);
    printf("\n");
    return 0;
}

// 90. Convert Lowercase to Uppercase and Vice Versa
