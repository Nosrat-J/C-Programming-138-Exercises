}

// 86. Insert a String into Another String
#include <stdio.h>
#include <string.h>
int main() {
    char mainStr[200], insStr[100];
    int pos;
    printf("Enter main string: ");
    scanf("%s", mainStr);
    printf("Enter string to insert: ");
    scanf("%s", insStr);
    printf("Enter position (0-index): ");
    scanf("%d", &pos);
    int lenMain = strlen(mainStr), lenIns = strlen(insStr);
    for (int i = lenMain; i >= pos; i--)
        mainStr[i + lenIns] = mainStr[i];
    for (int i = 0; i < lenIns; i++)
        mainStr[pos + i] = insStr[i];
    printf("Result: %s\n", mainStr);
    return 0;
}

