// 113. Find Longest Common Subsequence (LCS)
#include <stdio.h>
#include <string.h>
int max(int a, int b) { return (a > b) ? a : b; }
int lcs(char *X, char *Y, int m, int n) {
    if (m == 0 || n == 0) return 0;
    if (X[m - 1] == Y[n - 1]) return 1 + lcs(X, Y, m - 1, n - 1);
    else return max(lcs(X, Y, m, n - 1), lcs(X, Y, m - 1, n));
}
int main() {
    char X[100], Y[100];
    printf("Enter first string: ");
    scanf("%s", X);
    printf("Enter second string: ");
    scanf("%s", Y);
    printf("LCS length = %d\n", lcs(X, Y, strlen(X), strlen(Y)));
    return 0;
}

// 114. Check Balanced Parentheses Using Stack
#include <stdio.h>
#include <string.h>
#define MAX 100
char stack[MAX];
int top = -1;
void push(char c) { if (top < MAX - 1) stack[++top] = c; }
char pop() { return (top >= 0) ? stack[top--] : '\0'; }
int isMatchingPair(char open, char close) {
    return (open == '(' && close == ')') ||
           (open == '{' && close == '}') ||
           (open == '[' && close == ']');
}
int checkBalanced(char expr[]) {
    for (int i = 0; expr[i]; i++) {
        if (expr[i] == '(' || expr[i] == '{' || expr[i] == '[')
            push(expr[i]);
        else if (expr[i] == ')' || expr[i] == '}' || expr[i] == ']') {
            if (top == -1) return 0;
            char popped = pop();
            if (!isMatchingPair(popped, expr[i])) return 0;
        }
    }
    return (top == -1);
}
int main() {
    char expr[MAX];
    printf("Enter expression: ");
    scanf("%s", expr);
    if (checkBalanced(expr)) printf("Balanced\n");
    else printf("Not balanced\n");
    return 0;
}

// 115. Implement Matrix Multiplication (Dynamic Memory)
#include <stdio.h>
#include <stdlib.h>
int main() {
    int r1, c1, r2, c2;
    printf("Enter rows and cols of first matrix: ");
    scanf("%d %d", &r1, &c1);
    printf("Enter rows and cols of second matrix: ");
    scanf("%d %d", &r2, &c2);
    if (c1 != r2) { printf("Multiplication not possible\n"); return 1; }
    int **A = (int**)malloc(r1 * sizeof(int*));
    int **B = (int**)malloc(r2 * sizeof(int*));
    int **C = (int**)malloc(r1 * sizeof(int*));
    for (int i = 0; i < r1; i++) A[i] = (int*)malloc(c1 * sizeof(int));
    for (int i = 0; i < r2; i++) B[i] = (int*)malloc(c2 * sizeof(int));
    for (int i = 0; i < r1; i++) C[i] = (int*)calloc(c2, sizeof(int));
    printf("Enter first matrix:\n");
    for (int i = 0; i < r1; i++)
        for (int j = 0; j < c1; j++) scanf("%d", &A[i][j]);
    printf("Enter second matrix:\n");
    for (int i = 0; i < r2; i++)
        for (int j = 0; j < c2; j++) scanf("%d", &B[i][j]);
    for (int i = 0; i < r1; i++)
        for (int j = 0; j < c2; j++)
            for (int k = 0; k < c1; k++)
                C[i][j] += A[i][k] * B[k][j];
    printf("Product:\n");
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) printf("%d ", C[i][j]);
        printf("\n");
    }
    for (int i = 0; i < r1; i++) free(A[i]);
    for (int i = 0; i < r2; i++) free(B[i]);
    for (int i = 0; i < r1; i++) free(C[i]);
    free(A); free(B); free(C);
    return 0;
}

// 116. Transpose a Matrix Using Pointers
#include <stdio.h>
void transpose(int *mat, int *res, int rows, int cols) {
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            *(res + j * rows + i) = *(mat + i * cols + j);
}
int main() {
    int rows, cols;
    printf("Enter rows and columns: ");
    scanf("%d %d", &rows, &cols);
    int mat[rows][cols], res[cols][rows];
    printf("Enter elements:\n");
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            scanf("%d", &mat[i][j]);
    transpose(&mat[0][0], &res[0][0], rows, cols);
    printf("Transpose:\n");
    for (int i = 0; i < cols; i++) {
        for (int j = 0; j < rows; j++)
            printf("%d ", res[i][j]);
        printf("\n");
    }
    return 0;
}

