// 100. Implement Stack Using Array
#include <stdio.h>
#include <stdlib.h>
#define MAX 100
int stack[MAX], top = -1;
void push(int val) {
    if (top == MAX - 1) printf("Stack overflow\n");
    else stack[++top] = val;
}
int pop() {
    if (top == -1) { printf("Stack underflow\n"); return -1; }
    else return stack[top--];
}
void display() {
    if (top == -1) printf("Empty\n");
    else { for (int i = top; i >= 0; i--) printf("%d ", stack[i]); printf("\n"); }
}
int main() {
    int choice, val;
    while (1) {
        printf("\n1.Push 2.Pop 3.Display 4.Exit: ");
        scanf("%d", &choice);
        if (choice == 1) { printf("Value: "); scanf("%d", &val); push(val); }
        else if (choice == 2) { val = pop(); if (val != -1) printf("Popped %d\n", val); }
        else if (choice == 3) display();
        else break;
    }
    return 0;
}

// 101. Implement Queue Using Array
#include <stdio.h>
#define MAX 100
int queue[MAX], front = -1, rear = -1;
void enqueue(int val) {
    if (rear == MAX - 1) printf("Queue full\n");
    else { if (front == -1) front = 0; queue[++rear] = val; }
}
int dequeue() {
    if (front == -1 || front > rear) { printf("Empty\n"); return -1; }
    return queue[front++];
}
void display() {
    if (front == -1 || front > rear) printf("Empty\n");
    else for (int i = front; i <= rear; i++) printf("%d ", queue[i]); printf("\n");
}
int main() {
    int choice, val;
    while (1) {
        printf("\n1.Enqueue 2.Dequeue 3.Display 4.Exit: ");
        scanf("%d", &choice);
        if (choice == 1) { printf("Value: "); scanf("%d", &val); enqueue(val); }
        else if (choice == 2) { val = dequeue(); if (val != -1) printf("Dequeued %d\n", val); }
        else if (choice == 3) display();
        else break;
    }
    return 0;
}

// 102. Implement Circular Queue
#include <stdio.h>
#define MAX 5
int cqueue[MAX], front = -1, rear = -1;
void enqueue(int val) {
    if ((front == 0 && rear == MAX - 1) || (rear == (front - 1) % (MAX - 1)))
        printf("Full\n");
    else if (front == -1) { front = rear = 0; cqueue[rear] = val; }
    else if (rear == MAX - 1 && front != 0) { rear = 0; cqueue[rear] = val; }
    else { rear++; cqueue[rear] = val; }
}
int dequeue() {
    if (front == -1) { printf("Empty\n"); return -1; }
    int data = cqueue[front];
    if (front == rear) front = rear = -1;
    else if (front == MAX - 1) front = 0;
    else front++;
    return data;
}
void display() {
    if (front == -1) printf("Empty\n");
    else {
        if (rear >= front)
            for (int i = front; i <= rear; i++) printf("%d ", cqueue[i]);
        else {
            for (int i = front; i < MAX; i++) printf("%d ", cqueue[i]);
            for (int i = 0; i <= rear; i++) printf("%d ", cqueue[i]);
        }
        printf("\n");
    }
}
int main() {
    int choice, val;
    while (1) {
        printf("\n1.Enqueue 2.Dequeue 3.Display 4.Exit: ");
        scanf("%d", &choice);
        if (choice == 1) { printf("Value: "); scanf("%d", &val); enqueue(val); }
        else if (choice == 2) { val = dequeue(); if (val != -1) printf("Dequeued %d\n", val); }
        else if (choice == 3) display();
        else break;
    }
    return 0;
}

