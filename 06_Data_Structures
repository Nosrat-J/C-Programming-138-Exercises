    printf("Enter keys: ");
    for (int i = 0; i < n; i++) { scanf("%d", &key); insert(key); }
    display();
    return 0;
}

// 110. Find All Subsets of a Set (Using Recursion)
#include <stdio.h>
void printSubset(int arr[], int subset[], int n, int idx, int subsetIdx) {
    if (idx == n) {
        printf("{ ");
        for (int i = 0; i < subsetIdx; i++) printf("%d ", subset[i]);
        printf("}\n");
        return;
    }
    printSubset(arr, subset, n, idx + 1, subsetIdx);
    subset[subsetIdx] = arr[idx];
    printSubset(arr, subset, n, idx + 1, subsetIdx + 1);
}
int main() {
    int arr[] = {1, 2, 3};
    int n = sizeof(arr) / sizeof(arr[0]);
    int subset[n];
    printf("All subsets:\n");
    printSubset(arr, subset, n, 0, 0);
    return 0;
}

// 111. Implement Tower of Hanoi Problem
