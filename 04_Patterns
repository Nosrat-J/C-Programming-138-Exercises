// 57. Print Reverse Floyd Pattern Triangle Pyramid
#include <stdio.h>
int main() {
    int rows;
    printf("Enter number of rows: ");
    scanf("%d", &rows);
    int num = rows * (rows + 1) / 2;
    for (int i = rows; i >= 1; i--) {
        for (int j = 1; j <= i; j++)
            printf("%d ", num--);
        printf("\n");
    }
    return 0;
}
